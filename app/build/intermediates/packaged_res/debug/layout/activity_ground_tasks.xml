<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <!-- iOS style Back Arrow -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back_button_desc"
        android:src="@drawable/baseline_arrow_back_ios_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/accent_blue" />

    <!-- Header -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/gto"
        android:textColor="@color/text_ios_primary"
        android:textSize="34sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/backButton" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:text="@string/gto_subtitle"
        android:textColor="@color/text_ios_secondary"
        android:textSize="17sp"
        android:alpha="0.7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleText">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- GD -->
            <FrameLayout
                android:id="@+id/gdButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/gd_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/gd_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/gd_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- GPE -->
            <FrameLayout
                android:id="@+id/gpeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/gpe_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/gpe_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/gpe_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- PGT -->
            <FrameLayout
                android:id="@+id/pgtButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/pgt_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/pgt_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/pgt_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- GOR -->
            <FrameLayout
                android:id="@+id/gorButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/gor_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/gor_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/gor_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- LEC -->
            <FrameLayout
                android:id="@+id/lecButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/lec_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/lec_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/lec_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- HGT -->
            <FrameLayout
                android:id="@+id/hgtButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/hgt_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/hgt_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/hgt_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- IO -->
            <FrameLayout
                android:id="@+id/ioButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/io_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/io_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/io_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- CT -->
            <FrameLayout
                android:id="@+id/ctButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/ct_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/ct_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/ct_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- FGT -->
            <FrameLayout
                android:id="@+id/fgtButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginVertical="16dp" android:background="@color/fgt_color" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:text="@string/fgt_title" android:textColor="@color/text_ios_primary" android:textSize="18sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:fontFamily="sans-serif" android:text="@string/fgt_desc" android:textColor="@color/text_ios_secondary" android:textSize="14sp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
