<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="32dp">

    <!-- iOS style Back Arrow -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back_button_desc"
        android:src="@drawable/baseline_arrow_back_ios_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/accent_blue" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="272dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_top_toTopOf="parent"
        tools:layout_editor_absoluteX="80dp">

        <!-- App Logo/Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02"
            android:text="SSB WINGS"
            android:textColor="@color/text_ios_primary"
            android:textSize="40sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="64dp"
            android:alpha="0.7"
            android:fontFamily="sans-serif"
            android:text="@string/login_subtitle"
            android:textColor="@color/text_ios_secondary"
            android:textSize="17sp" />

        <!-- Username Field with Glass Aesthetic -->
        <EditText
            android:id="@+id/usernameField"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/glass_background"
            android:fontFamily="sans-serif"
            android:hint="@string/username_hint"
            android:inputType="text"
            android:paddingHorizontal="20dp"
            android:textColor="@color/text_ios_primary"
            android:textColorHint="@color/text_ios_tertiary"
            android:textSize="17sp" />

        <!-- Password Field with Glass Aesthetic -->
        <EditText
            android:id="@+id/passwordField"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/glass_background"
            android:fontFamily="sans-serif"
            android:hint="@string/password_hint"
            android:inputType="textPassword"
            android:paddingHorizontal="20dp"
            android:textColor="@color/text_ios_primary"
            android:textColorHint="@color/text_ios_tertiary"
            android:textSize="17sp" />

        <!-- Modern Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/login_button"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_blue"
            app:cornerRadius="14dp"
            app:elevation="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
