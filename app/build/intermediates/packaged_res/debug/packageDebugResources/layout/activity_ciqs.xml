<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/glass_background_circle"
            android:src="@drawable/baseline_arrow_back_ios_24"
            app:tint="@color/text_primary"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Interview CIQs"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comprehensive Interview Question Sets"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- CIQ 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CIQ 1: Academic &amp; Sports" android:textColor="@color/google_blue" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="• Tell me about your academic journey from 10th standard onwards.\n• What were your favorite subjects and why?\n• Mention subjects you liked the least and why?\n• Tell me about your favorite teachers and why they were your favorite?\n• Any teachers you didn't like?\n• Mention your achievements in academics and sports.\n• Tell me about your participation in extra-curricular activities."
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CIQ 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CIQ 2: Family &amp; Friends" android:textColor="@color/google_green" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="• Tell me about your family members and their occupations.\n• What is your relationship with each family member?\n• Who are you closest to and why?\n• How do you help your parents at home?\n• How do you spend your pocket money?\n• Tell me about your best friends and why they are your best friends.\n• What do they like and dislike about you?"
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CIQ 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CIQ 3: Routine &amp; Self-Awareness" android:textColor="@color/google_yellow" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="• Tell me about your daily routine from morning to night.\n• How do you spend your weekends?\n• What are your hobbies and interests?\n• What are your 3 biggest strengths and 3 weaknesses?\n• How are you working on your weaknesses?\n• Tell me about a time you faced a major challenge and how you overcame it."
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CIQ 4 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CIQ 4: Career &amp; Why Forces" android:textColor="@color/google_red" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="• Why do you want to join the Armed Forces?\n• Why did you choose this particular service (Army/Navy/Air Force)?\n• What have you done to prepare for this SSB?\n• If you are not selected this time, what is your Plan B?\n• What are your current career goals if you are working/studying?"
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CIQ 5 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CIQ 5: GK &amp; Current Affairs" android:textColor="@color/primary_indigo" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="• Tell me about 3 major national news from the last month.\n• Tell me about 2 major international events.\n• Who is the current Chief of your chosen service?\n• Tell me about the recent defense acquisitions or developments in India.\n• Geographical facts about your native place and current city."
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CIQ 6 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CIQ 6: Service Knowledge" android:textColor="@color/apple_pink" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="• What are the ranks in the Army/Navy/Air Force?\n• Mention the various commands of your chosen service.\n• What are the latest weapons or aircrafts used by the service?\n• Tell me about the recent operations conducted by the Armed Forces.\n• Why should we select you as an officer?"
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
