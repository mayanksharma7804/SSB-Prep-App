<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="@string/home_welcome"
            android:textColor="@color/text_ios_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/logout_button"
            android:textAllCaps="false"
            android:textColor="@color/accent_blue"
            android:textSize="17sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:text="@string/home_subtitle"
        android:textColor="@color/text_ios_secondary"
        android:textSize="17sp"
        android:alpha="0.7"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- Grid of Sections -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <!-- Screening -->
            <FrameLayout
                android:id="@+id/screeningBlock"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="bottom">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/screening" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/screening"
                        android:textColor="@color/text_ios_primary"
                        android:textSize="18sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Ground Tasks -->
            <FrameLayout
                android:id="@+id/groundTasksBlock"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="bottom">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/gto" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/gto"
                        android:textColor="@color/text_ios_primary"
                        android:textSize="18sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Psychology -->
            <FrameLayout
                android:id="@+id/psychologyBlock"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="bottom">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/psychology" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/psychology"
                        android:textColor="@color/text_ios_primary"
                        android:textSize="18sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Interview -->
            <FrameLayout
                android:id="@+id/interviewBlock"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/glass_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="bottom">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/interview" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/interview"
                        android:textColor="@color/text_ios_primary"
                        android:textSize="18sp" />
                </LinearLayout>
            </FrameLayout>

        </GridLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
