<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/glass_background_circle"
            android:src="@drawable/baseline_arrow_back_ios_24"
            app:tint="@color/text_primary"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Guidelines &amp; Tips"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <!-- Fundamental Advice -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Evaluation Criteria" android:textColor="@color/primary_blue" android:textSize="14sp" android:textStyle="bold" android:textAllCaps="true" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="Interviewing officers look for 15 Officer Like Qualities (OLQs). You are recommended if at least 7–8 OLQs are good and others are average."
                        android:textColor="@color/text_primary" android:textSize="15sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Answering Style" android:textColor="@color/google_green" android:textSize="14sp" android:textStyle="bold" android:textAllCaps="true" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="• Be logical, truthful, and maintain a positive mindset.\n• Avoid lying at all costs; transparency is valued.\n• Demeanor: Be natural, cheerful, attentive, and smile openly."
                        android:textColor="@color/text_primary" android:textSize="15sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rapid Fire Questions" android:textColor="@color/google_yellow" android:textSize="14sp" android:textStyle="bold" android:textAllCaps="true" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="Count questions on your fingers to ensure every part is answered logically one by one. This tests effective intelligence, reasoning, expression, and confidence."
                        android:textColor="@color/text_primary" android:textSize="15sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Concluding the Interview" android:textColor="@color/google_red" android:textSize="14sp" android:textStyle="bold" android:textAllCaps="true" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="When asked if you have questions, it is advised to say: 'Thank you sir, I don\'t have any question'. Never ask about your performance or selection."
                        android:textColor="@color/text_primary" android:textSize="15sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hypothetical: Proposed Changes" android:textColor="@color/primary_indigo" android:textSize="14sp" android:textStyle="bold" android:textAllCaps="true" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="If asked what changes you'd bring as an officer:\n• Issue bulletproof jackets to all personnel.\n• Name rifles in the armoury to foster a personal bond.\n• Base-wide CCTV for enhanced security."
                        android:textColor="@color/text_primary" android:textSize="15sp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
